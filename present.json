              "raw": "{\r\n    \"name\":\"user\",\r\n    \"telephone\":\"{{$randomPhoneNumber}}\",\r\n    \"email\": \"{{$randomFirstName}}@gmail.com\",\r\n    \"password\": \"{{$randomPassword}}\",\r\n    \"role\": \"user\"\r\n}\r\n",
