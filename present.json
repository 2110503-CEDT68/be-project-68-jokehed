          "name": "user register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.globals.set(\"token\", pm.response.json().token);\r",
                  "\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "// อ่าน body JSON ที่ส่งไป\r",
                  "const requestBody = JSON.parse(pm.request.body.raw);\r",
                  "\r",
                  "// เก็บเป็น Global variables\r",
                  "pm.globals.set(\"user_email\", requestBody.email);\r",
                  "pm.globals.set(\"user_password\", requestBody.password);\r",
                  "\r",
                  "console.log(\"Saved name & password to global variables\");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "description": "JSON Type",
                "type": "text"
